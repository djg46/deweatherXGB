Package: deweatherXGB
Type: Package
Title: Remove the influence of weather on air quality data (xgboost)
Version: 0.1.0
Authors@R: c(
    person(
      "David", "Carslaw",
      email = "david.carslaw@york.ac.uk",
      role = "aut", comment = c(ORCID = "0000-0003-0991-950X")
    ),
    person("Doug", "Gregg",
